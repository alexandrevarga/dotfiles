{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#9ca3af",
          "style": "plain",
          "template": "\uf0e7 {{ .UserName }}@{{ .HostName }} in ",
          "type": "session"
        },
        {
          "foreground": "#00afff",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "\uf115 {{ .Path }}",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#906cff",
          "style": "plain",
          "template": "\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "foreground": "#ff8080",
          "style": "plain",
          "template": "\ue20f {{ .FormattedMs }} ",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#00afff",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f97316{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#7c5da0{{ end }}",
            "{{ if gt .Ahead 0 }}#7c5da0{{ end }}",
            "{{ if gt .Behind 0 }}#7c5da0{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "\ue702 {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} \uf044 {{ .Working.String }}{{ end }}{{ if gt .Ahead 0 }} \u2191{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} \u2193{{ .Behind }}{{ end }}",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#00afff",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 3
}
