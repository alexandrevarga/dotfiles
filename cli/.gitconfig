# This is Git's per-user configuration file.
[user]
	name = Alexandre Varga
	email = alexandrevargadev@gmail.com
	signingkey = /home/alexandre/.ssh/id_ed25519.pub
[core]
	editor = nano
[init]
	defaultBranch = main
[pull]
	rebase = true
[alias]
	st = status
	co = checkout
	br = branch
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = /home/alexandre/.ssh/allowed_signers
